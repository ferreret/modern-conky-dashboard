# Proxmox API connection — copy this file to .proxmox.env and fill in
# Crear el token en Proxmox: Datacenter > Permissions > API Tokens
# Recommended: user PVEAuditor role (read-only)

PVE_HOST=192.168.1.10
PVE_PORT=8006
PVE_TOKEN_ID=root@pam!conky
PVE_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 1 = ignorar certificado autofirmado (homelab), 0 = verificar
PVE_INSECURE=1
